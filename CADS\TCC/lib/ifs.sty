%Remove as bordas do hyperlinks e melhora a configuração
\newcommand{\removerbordasdohyperlink}[1]{%
	\ifthenelse{\equal{#1}{sim}}{%
  		\hypersetup{%
  		    pdfborder = {0 0 0},
  		    hidelinks,                    % Remove todas as bordas
  		    pdfpagemode=UseOutlines,      % Abre com outline
  		    pdfstartview=Fit,            % Ajusta à janela
  		    pdfdisplaydoctitle=true,     % Mostra título na barra
  		    pdfcreator={LaTeX via abnTeX2 + uecetex2}, % Criador
  		    pdfproducer={LaTeX}          % Produtor
  		}
    }
}

% Configura cor e aparência dos hyperlinks
\newcommand{\cordohyperlink}[1]{%
	\ifthenelse{\equal{#1}{sim}}{%
		\hypersetup{%
			colorlinks = true,
			linkcolor = blue,
			filecolor = magenta,
			urlcolor = blue,
			citecolor = blue,
			anchorcolor = black
		}
	}
}

% Adiciona o sexo do orientador e do co-orientador no documento atraves
% do artigo "a".

\provideboolean{uecetex2@orientadorfeminino}
\provideboolean{uecetex2@coorientadorfeminino}

\setboolean{uecetex2@orientadorfeminino}{false}
\setboolean{uecetex2@coorientadorfeminino}{false}

\newcommand{\orientadorfeminino}[1]{
	 \ifthenelse{\equal{#1}{sim}}{%
	 	\setboolean{uecetex2@orientadorfeminino}{true}
	 }
}

\newcommand{\coorientadorfeminino}[1]{
	\ifthenelse{\equal{#1}{sim}}{%
		\setboolean{uecetex2@coorientadorfeminino}{true}
	}
}

\newcommand{\artigoorientador}{ %
	\ifthenelse{\boolean{uecetex2@orientadorfeminino}}{ %
		\unskip Orientadora\ignorespaces%
	}{ %
		\unskip Orientador\ignorespaces%
	} %
}

\newcommand{\artigocoorientador}{ %
	\ifthenelse{\boolean{uecetex2@coorientadorfeminino}}{ %
		Co-Orientadora\ignorespaces%
	}{ %
		Co-Orientador\ignorespaces%
	} %
}

\newcommand{\artigoorientadorcomparenteses}{ %
	\ifthenelse{\boolean{uecetex2@orientadorfeminino}}{ %
		(Orientadora)\ignorespaces%
	}{ %
		(Orientador)\ignorespaces%
	} %
}

\newcommand{\artigocoorientadorcomparenteses}{ %
	\ifthenelse{\boolean{uecetex2@coorientadorfeminino}}{ %
