% Determina o tipo do trabalho apresentado
% Definicao das variaveis
\provideboolean{uecetex2@ehtccgraduacao}
\provideboolean{uecetex2@ehtccespecializacao}
\provideboolean{uecetex2@ehdissertacao}
\provideboolean{uecetex2@ehtese}

% Valores Iniciais
\setboolean{uecetex2@ehtccgraduacao}{false}
\setboolean{uecetex2@ehtccespecializacao}{false}
\setboolean{uecetex2@ehdissertacao}{true}
\setboolean{uecetex2@ehtese}{false}

\newcommand{\trabalhoacademico}[1]{
	\setboolean{uecetex2@ehtccgraduacao}{false}
	\setboolean{uecetex2@ehtccespecializacao}{false}
	\setboolean{uecetex2@ehdissertacao}{false}
	\setboolean{uecetex2@ehtese}{false}
	
	\ifthenelse{\equal{#1}{tccgraduacao}}{%
		\setboolean{uecetex2@ehtccgraduacao}{true}
	}{
		\ifthenelse{\equal{#1}{tccespecializacao}}{%
			\setboolean{uecetex2@ehtccespecializacao}{true}
		}{
			\ifthenelse{\equal{#1}{dissertacao}}{%
				\setboolean{uecetex2@ehdissertacao}{true}
			}{
				\ifthenelse{\equal{#1}{tese}}{%
					\setboolean{uecetex2@ehtese}{true}
				}{
					\setboolean{uecetex2@ehdissertacao}{true}
				}
			}
		}	
	}
}

